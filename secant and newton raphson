#include<iostream>
#include<vector>
#include<fstream>
#include<cmath>
#include<iomanip>

using namespace std;

 double evaluate(double c1, const vector<double>& coeff) {
     double total = 0;
    for (int i = 0; i < coeff.size(); i++) {
        total += coeff[i] * pow(c1, i);
    }
    return total;
}

// Secant Method
double solveSecant(double x0, double x1, const vector<double>& d_Coef) {

    double x_prev = x0;
    double x_curr = x1;

    for (int i = 0; i < 30; i++) {
        double f_prev = evaluate(x_prev, d_Coef);
        double f_curr = evaluate(x_curr, d_Coef);

        if (fabsl(f_curr - f_prev) < 1e-18) break;
        double x = f_curr * (x_curr - x_prev) / (f_curr - f_prev);
        double x_next = x_curr - x;

        if (fabsl(x_next - x_curr) < 1e-10)
            return x_next;

        x_prev = x_curr;
        x_curr = x_next;
    }

    return x_curr;
}

// Newton-Raphson Method
double solveNewtonRaphson(double x_guess, const vector<double>& d_Coef) {

    vector<double> secondDerivCoeffs;
    for (int i = 1; i < d_Coef.size(); i++) {
        secondDerivCoeffs.push_back(i*d_Coef[i]);
    }

    double x = x_guess;

    for (int i = 0; i < 30; i++) {
        double fx = evaluate(x, d_Coef);
        double dfx = evaluate(x, secondDerivCoeffs);

        if (fabsl(dfx) < 1e-10) break;

        double x_next = x - fx / dfx;

        if (fabsl(x_next - x) < 1e-12)
            return x_next;

        x = x_next;
    }

    return x;
}

//  FUNCTION : to find all the roots within domain
vector<double> findAllRoots(double a,double b,int steps,const vector<double>& d_Coef,string method) {
    vector<double> roots;
    double step = (b - a) / steps;

    for (int i = 0; i < steps; i++) {

        double x1 = a + i * step;
        double x2 = x1 + step;

        double f1 = evaluate(x1, d_Coef);
        double f2 = evaluate(x2, d_Coef);

        // if f1*f2 is negative then there will be a root between these points
        if (f1 * f2 <= 0) {

             double root;

            if (method == "secant") {
                root = solveSecant(x1, x2, d_Coef);
            } else { // newton
                 double mid = (x1 + x2) / 2;
                root = solveNewtonRaphson(mid, d_Coef);
            }

            // root should be within domain
            if (root < a || root > b) continue;

            // avoid duplicates
            int c = 1;
            for (auto r : roots) {
                if (fabsl(r - root) < 1e-6) {
                    c = 0;
                    break;
                }
            }
            if (c) {
                roots.push_back(root);
            }
            
        }
    }

    return roots;
}

int main(){

    // read data
    string s;
    // taking input as the name of method of which we need to find derivate roots.
    cin>>s;
    string y =s+".csv";
    
    ifstream file(y);

    vector<double> coeff_standard;
     double coeff_val;

    while(file >> coeff_val) {
        coeff_standard.emplace_back(coeff_val);
    }

    file.close();

    // derivative coefficients p'(x)
    vector<double> derivCoeffs;
    for (int i = 1; i < coeff_standard.size(); i++) {
        derivCoeffs.push_back(i * coeff_standard[i]);
    }

    if (coeff_standard.size() > 2) {

        string method = "newton "; 

        vector<double> roots = findAllRoots(-1.0, 1.0, 200, derivCoeffs, method);

        cout << fixed << setprecision(10);
        cout << "\nRoots using " << method << " method in [-1,1]:\n\n";

        for (int i = 0; i < roots.size(); i++) {
            cout << "Root " << i+1 << " = " << roots[i] << endl;
        }
    }
    if (coeff_standard.size() > 2) {

        string method = "secant ";  

        vector<double> roots = findAllRoots(-1.0, 1.0, 200, derivCoeffs, method);

        cout << fixed << setprecision(10);
        cout << "\nRoots using " << method << " method in [-1,1]:\n\n";

        for (int i = 0; i < roots.size(); i++) {
            cout << "Root " << i+1 << " = " << roots[i] << endl;
        }
    }
    cout<<endl;

    return 0;
}
